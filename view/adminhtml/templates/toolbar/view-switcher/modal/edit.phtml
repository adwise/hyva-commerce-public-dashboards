                                            <span x-show="copied" x-cloak><?= /** @noEscape */ $icons->checkHtml('', 20, 20, ['aria-hidden' => 'true']); ?></span>
                                        </button>
                                    </div>
                                </template>
                                <p x-show="isSharedView()">
                                    <?= $escaper->escapeHtml(__('Generating a new link invalidates the current one.')); ?>
                                </p>
                                <p x-show="publicUrl && !isSharedView()" x-cloak>
                                    <?= $escaper->escapeHtml(__(
                                        'The public link currently points to another view. '
                                        . 'Generating a link here will replace it.'
                                    )); ?>
                                </p>
                                <div class="actions-toolbar public-dashboard-actions">
                                    <button type="button"
                                            class="action action-secondary"
                                            :disabled="isBusy"
