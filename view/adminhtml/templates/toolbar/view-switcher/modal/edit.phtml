        class="view-manager-edit-modal widget-modal-overlay small-modal">
    <div class="widget-modal-container">
        <div class="widget-modal-header">
            <div class="widget-modal-icon">
                <?= $icons->scanEyeHtml('', 20, 20, ['aria-hidden' => 'true']) ?>
